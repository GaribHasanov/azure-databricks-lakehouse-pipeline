{
  "name": "lakehouse_pipeline",
  "properties": {
    "description": "Orchestrates Databricks Lakehouse ETL (Bronze -> Silver -> Gold)",
    "activities": [
      {
        "name": "Bronze_Ingestion",
        "type": "DatabricksNotebook",
        "dependsOn": [],
        "typeProperties": {
          "notebookPath": "/databricks/notebooks/ingest_to_bronze",
          "baseParameters": {}
        },
        "linkedServiceName": {
          "referenceName": "AzureDatabricksLinkedService",
          "type": "LinkedServiceReference"
        }
      },
      {
        "name": "Silver_Transformation",
        "type": "DatabricksNotebook",
        "dependsOn": [
          {
            "activity": "Bronze_Ingestion",
            "dependencyConditions": ["Succeeded"]
          }
        ],
        "typeProperties": {
          "notebookPath": "/databricks/notebooks/transform_to_silver",
          "baseParameters": {}
        },
        "linkedServiceName": {
          "referenceName": "AzureDatabricksLinkedService",
          "type": "LinkedServiceReference"
        }
      },
      {
        "name": "Gold_Load",
        "type": "DatabricksNotebook",
        "dependsOn": [
          {
            "activity": "Silver_Transformation",
            "dependencyConditions": ["Succeeded"]
          }
        ],
        "typeProperties": {
          "notebookPath": "/databricks/notebooks/load_to_gold",
          "baseParameters": {}
        },
        "linkedServiceName": {
          "referenceName": "AzureDatabricksLinkedService",
          "type": "LinkedServiceReference"
        }
      }
    ]
  }
}
