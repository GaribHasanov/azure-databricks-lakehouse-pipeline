{
  "name": "retail_lakehouse_pipeline",
  "properties": {
    "description": "End-to-end retail lakehouse pipeline (Bronze → Silver → Gold)",
    "activities": [
      
      {
        "name": "Ingest_Sales_Bronze",
        "type": "DatabricksNotebook",
        "dependsOn": [],
        "typeProperties": {
          "notebookPath": "/databricks/notebooks/ingest_sales_to_bronze"
        }
      },

      {
        "name": "Ingest_Products_Bronze",
        "type": "DatabricksNotebook",
        "dependsOn": [],
        "typeProperties": {
          "notebookPath": "/databricks/notebooks/ingest_products_to_bronze"
        }
      },

      {
        "name": "Build_Fact_Sales",
        "type": "DatabricksNotebook",
        "dependsOn": [
          {
            "activity": "Ingest_Sales_Bronze",
            "dependencyConditions": ["Succeeded"]
          }
        ],
        "typeProperties": {
          "notebookPath": "/databricks/notebooks/build_fact_sales"
        }
      },

      {
        "name": "Build_Dim_Product",
        "type": "DatabricksNotebook",
        "dependsOn": [
          {
            "activity": "Ingest_Products_Bronze",
            "dependencyConditions": ["Succeeded"]
          }
        ],
        "typeProperties": {
          "notebookPath": "/databricks/notebooks/build_dim_product"
        }
      },

      {
        "name": "Build_Dim_Store",
        "type": "DatabricksNotebook",
        "dependsOn": [
          {
            "activity": "Ingest_Sales_Bronze",
            "dependencyConditions": ["Succeeded"]
          }
        ],
        "typeProperties": {
          "notebookPath": "/databricks/notebooks/build_dim_store"
        }
      },

      {
        "name": "Build_Dim_Customer",
        "type": "DatabricksNotebook",
        "dependsOn": [
          {
            "activity": "Ingest_Sales_Bronze",
            "dependencyConditions": ["Succeeded"]
          }
        ],
        "typeProperties": {
          "notebookPath": "/databricks/notebooks/build_dim_customer"
        }
      },

      {
        "name": "Build_Dim_Promotion",
        "type": "DatabricksNotebook",
        "dependsOn": [
          {
            "activity": "Build_Dim_Product",
            "dependencyConditions": ["Succeeded"]
          }
        ],
        "typeProperties": {
          "notebookPath": "/databricks/notebooks/build_dim_promotion"
        }
      },

      {
        "name": "Build_Gold_KPIs",
        "type": "DatabricksNotebook",
        "dependsOn": [
          {
            "activity": "Build_Fact_Sales",
            "dependencyConditions": ["Succeeded"]
          },
          {
            "activity": "Build_Dim_Product",
            "dependencyConditions": ["Succeeded"]
          },
          {
            "activity": "Build_Dim_Store",
            "dependencyConditions": ["Succeeded"]
          }
        ],
        "typeProperties": {
          "notebookPath": "/databricks/notebooks/build_sales_kpis"
        }
      }

    ]
  }
}
