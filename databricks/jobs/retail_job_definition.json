{
  "name": "retail_lakehouse_batch_job",
  "max_concurrent_runs": 1,
  "timeout_seconds": 7200,

  "tasks": [

    {
      "task_key": "ingest_bronze_sales",
      "notebook_task": {
        "notebook_path": "/Workspace/databricks/notebooks/ingest_sales_to_bronze"
      },
      "new_cluster": {
        "spark_version": "13.3.x-scala2.12",
        "node_type_id": "Standard_DS3_v2",
        "num_workers": 2
      }
    },

    {
      "task_key": "ingest_bronze_products",
      "notebook_task": {
        "notebook_path": "/Workspace/databricks/notebooks/ingest_products_to_bronze"
      },
      "new_cluster": {
        "spark_version": "13.3.x-scala2.12",
        "node_type_id": "Standard_DS3_v2",
        "num_workers": 2
      }
    },

    {
      "task_key": "build_fact_sales",
      "depends_on": [
        { "task_key": "ingest_bronze_sales" }
      ],
      "notebook_task": {
        "notebook_path": "/Workspace/databricks/notebooks/build_fact_sales"
      },
      "new_cluster": {
        "spark_version": "13.3.x-scala2.12",
        "node_type_id": "Standard_DS3_v2",
        "num_workers": 2
      }
    },

    {
      "task_key": "build_dimensions",
      "depends_on": [
        { "task_key": "ingest_bronze_sales" },
        { "task_key": "ingest_bronze_products" }
      ],
      "notebook_task": {
        "notebook_path": "/Workspace/databricks/notebooks/build_dim_product"
      },
      "new_cluster": {
        "spark_version": "13.3.x-scala2.12",
        "node_type_id": "Standard_DS3_v2",
        "num_workers": 2
      }
    },

    {
      "task_key": "build_gold_kpis",
      "depends_on": [
        { "task_key": "build_fact_sales" },
        { "task_key": "build_dimensions" }
      ],
      "notebook_task": {
        "notebook_path": "/Workspace/databricks/notebooks/build_sales_kpis"
      },
      "new_cluster": {
        "spark_version": "13.3.x-scala2.12",
        "node_type_id": "Standard_DS3_v2",
        "num_workers": 2
      }
    }

  ]
}
